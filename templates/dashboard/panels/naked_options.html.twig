<div class="panel large_panel" style="padding:20px; background: #fff;">
    <div class="bg-white text-start">
        <div class="max-w-7xl mx-auto">
            <div class="px-4 sm:px-6 lg:px-8">
                <div class="mt-8 flow-root">
                    <div class="mx-[-1rem] my-[-0.5rem] overflow-x-auto sm:mx-6 lg:mx-[-2rem]">
                        <div class="inline-block min-w-full py-2 align-middle sm:px-6 lg:px-8">
                            <table class="indent-0 border-inherit border-collapse min-w-full table-table table-body">
                                <thead>
                                <tr>
                                    <th scope="col" class="py-3.5 pl-4 text-center text-sm leading-5 font-semibold text-gray-900 sm:pl-0">Stock</th>
                                    <th scope="col" class="py-3.5 pl-4 text-center text-sm leading-5 font-semibold text-gray-900 sm:pl-0">Expiry Date</th>
                                    <th scope="col" class="pl-3 py-3.5 text-center text-sm leading-5 font-semibold text-gray-900">Contracts</th>
                                    <th scope="col" class="pl-3 py-3.5 text-center text-sm leading-5 font-semibold text-gray-900">Average</th>
                                    <th scope="col" class="pl-3 py-3.5 text-center text-sm leading-5 font-semibold text-gray-900">Current</th>
                                    <th scope="col" class="pl-3 py-3.5 text-center text-sm leading-5 font-semibold text-gray-900">P/L</th>
{#                                    <th scope="col" class="pl-3 py-3.5 text-center text-sm leading-5 font-semibold text-gray-900">Needed</th>#}
                                </tr>
                                </thead>
                                <tbody class="bg-white">
                                {% for stock in stocks %}
                                {% for option in stock.options %}
                                    {% if option.expired == false and option.totalContractsSold == 0 %}
                                    <tr>
                                        <td class="whitespace-nowrap py-5 pl-3 text-sm sm:pl-0">
                                            <div class="w-16 h-16 p-3 shadow rounded-full" style="background-color:#{{ stock.company.bgColor }};">
                                                {% if stock.company.useSVG %}
                                                    <a href="/stocks/details/{{ stock.id }}"><img src="/assets/images/company_logos/svg/{{ stock.company.ticker }}.svg" alt="{{ stock.company.ticker }} Logo" class="block align-middle max-w-full w-12 h-12 rounded-full"/></a>
                                                {% else %}
                                                    <a href="/stocks/details/{{ stock.id }}"><img src="/assets/images/company_logos/{{ stock.company.ticker }}.jpg" alt="{{ stock.company.ticker }} Logo" class="block align-middle max-w-full w-12 h-12 rounded-full"/></a>
                                                {% endif %}

                                            </div>
                                        </td>
                                        <td class="whitespace-nowrap px-3 py-5 text-sm text-gray-500">
                                            <div class="ml-4 text-center">{{ option.expiry|date("m/d/Y") }}</div>
                                        </td>
                                        <td class="whitespace-nowrap px-3 py-5 text-sm text-gray-500">
                                            <div class="ml-4 text-center">{{ option.contracts }}</div>
                                        </td>
                                        <td class="whitespace-nowrap px-3 py-5 text-sm text-gray-500">
                                            <div class="ml-4 text-center">{{ option.average|number_format(2) }}</div>
                                        </td>
                                        {% set current = option.current %}
{#                                        {% set current = option.current + 0.08 %}#}
                                        {% set cost = ((option.average * 100) * option.contracts) + 9.95 + (1.25 * option.contracts) %}
                                        {% set earn = ((current * 100) * option.contracts) - 9.95 - (1.25 * option.contracts)  %}
                                        {% set option_pl = earn - cost %}
                                        {% set needed = (earn - cost) / 100 / option.contracts %}
                                        {% if needed < 0 %}
                                            {% set needed = (needed * -1) + current %}
                                        {% else %}
                                            {% set needed = current - needed %}
                                        {% endif %}
                                        <td class="whitespace-nowrap px-3 py-5 text-sm text-gray-500">
                                            <div class="ml-4 text-center">{{ current|number_format(2) }} | {{ needed|number_format(2) }}</div>
                                        </td>

                                        <td class="whitespace-nowrap px-3 py-5 text-sm text-gray-500">
                                            <div class="ml-4 text-center">{% if option_pl < 0.00 %}-${{ (option_pl * -1)|number_format(2) }}{% else %}${{ option_pl|number_format(2) }}{% endif %}</div>
                                        </td>

{#                                        <td class="whitespace-nowrap px-3 py-5 text-sm text-gray-500">#}
{#                                            <div class="ml-4 text-center">{{ needed|number_format(2) }}</div>#}
{#                                        </td>#}
                                    </tr>

                                    {# -- Debug Data -- #}
{#                                    <tr>#}
{#                                        <td>-${{ cost }}</td>#}
{#                                        <td>${{ earn }}</td>#}
{#                                        <td>{% if option_pl < 0.00 %}-{% endif %}${{ option_pl|number_format(2) }}</td>#}
{#                                        <td>{{ needed }}</td>#}
{#                                    </tr>#}
                                    {% endif %}
                                {% endfor %}
                                {% endfor %}
                                <tr>
                                    <td colspan="6">
                                        <button id="NOUpdateBtn" class="rounded-lg w-full cursor-pointer text-white bg-gradient-to-r from-green-400 via-green-500 to-green-600 hover:bg-gradient-to-br focus:ring-4 focus:outline-none focus:ring-green-300 dark:focus:ring-green-800 font-medium rounded-base text-sm px-4 py-2.5 text-center leading-5">Refresh Data</button>
                                    </td>
                                </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const updateBtn = document.querySelector('#NOUpdateBtn');

        if (updateBtn) {
            updateBtn.addEventListener('click', function() {
                // Optional: Disable button to prevent double-clicks
                this.disabled = true;
                this.textContent = 'Updating...';
                var xxx = this;

                fetch('/dashboard/updateNakedOptions', {
                    method: 'POST', // or 'GET' depending on your controller route
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest',
                        'X-CSRF-TOKEN': updateBtn.dataset.token,
                        'Content-Type': 'application/json'
                    }
                })
                    .then(response => {
                        if (!response.ok) throw new Error('Network response was not ok');
                        return response.json();
                    })
                    .then(data => {
                        if (data.success === true) {
                            xxx.textContent = 'Update Complete, Refreshing now...';
                            // Refresh the page as requested
                            //console.log(data);
                            window.location.reload();
                        } else {
                            alert('Update failed: ' + (data.message || 'Unknown error'));
                            this.disabled = false;
                            this.textContent = 'Update';
                        }
                    })
                    .catch(error => {
                        console.error('Error:', error);
                        alert('An error occurred during the update.');
                        this.disabled = false;
                        this.textContent = 'Update';
                    });
            });
        }
    });
</script>